# Пример переменных окружения. Реальные значения НЕ коммитить.
#
# Клиентские ключи приложения передаются в сборку через --dart-define
# (см. README / RELEASE.md). Серверные секреты (service role, секретные ключи
# YooKassa/OneSignal) задаются ТОЛЬКО на сервере: `supabase secrets set ...`.

# --- Клиент (Flutter, через --dart-define) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
ONESIGNAL_APP_ID=your-onesignal-app-id

# Режим оплаты: test (мгновенное подтверждение) | prod (YooKassa + webhook)
PAYMENT_MODE=test
# URL возврата после оплаты (для закрытия WebView в prod-режиме)
PAYMENT_RETURN_URL=https://your-domain.example/payment-result

# --- Сервер (Supabase Edge Functions, через `supabase secrets set`) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key
YOOKASSA_SHOP_ID=your-yookassa-shop-id
YOOKASSA_SECRET_KEY=your-yookassa-secret-key
